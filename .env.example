# Copy this file to .env and fill in real values. Never commit the real .env.
SECRET_KEY=change-me-generate-with-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Hidden admin URL (must end with a slash). Pick your own secret path.
ADMIN_URL=admin/

# Gmail SMTP for admin password recovery (use a Google App Password, not your login password).
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=you@gmail.com

# Optional: lock the account after this many failed logins.
AXES_FAILURE_LIMIT=5
